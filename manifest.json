{
  "manifest_version": 3,
  "name": "Routeva — VPN и прокси",
  "short_name": "Routeva",
  "version": "0.8.0",
  "description": "Направляет выбранные сайты или весь интернет через ваш Routeva Gateway и переключает узлы подписок.",
  "homepage_url": "https://github.com/rub1kub/amnezia-split-extension",
  "minimum_chrome_version": "109",
  "permissions": [
    "alarms",
    "proxy",
    "storage",
    "tabs",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/update-banner.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Routeva",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "incognito": "spanning"
}
